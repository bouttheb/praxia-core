# Postgres connection string. Neon, Supabase, local Postgres, and Vercel Postgres all work.
DATABASE_URL=postgres://praxia:praxia@localhost:5432/praxia

# Shared secret used by the daemon when it claims and reports command runs.
# Generate one with: openssl rand -hex 32
DASHBOARD_WRITE_KEY=

# Optional browser/API command key. If unset, the local UI can queue commands without this header.
COMMAND_KEY=

# Hosted Praxia Cloud mode is disabled by default. Leave this unset or self-hosted
# for local installs. A hosted deployment can set PRAXIA_MODE=cloud after adding auth.
PRAXIA_MODE=self-hosted
HOSTED_ADMIN_KEY=

# Optional daemon settings.
DASHBOARD_URL=http://localhost:3030
DAEMON_ID=home-machine
DAEMON_CONCURRENCY=1
DAEMON_POLL_INTERVAL_MS=5000
CLAUDE_BIN=claude
CODEX_BIN=codex
